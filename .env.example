## ───── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

## ───── App auth (must match frontend JWT_SECRET) ───────────────────
JWT_SECRET=

## ───── Internal relay (Next.js → Nest) ────────────────────────────
THALOS_INTERNAL_SECRET=

## ───── HTTP / CORS ────────────────────────────────────────────────
PORT=3001
THALOS_CORS_ORIGIN=http://localhost:3000
THALOS_APP_PUBLIC_URL=http://localhost:3000

## ───── Stellar / Trustless Work ───────────────────────────────────
TRUSTLESSWORK_API_URL=https://api.trustlesswork.com
TRUSTLESSWORK_API_KEY=
STELLAR_NETWORK=testnet

## ───── Resend (transactional email) ──────────────────────────────
# Keep names in sync with ThalosFrontend `lib/email/resend.ts`.
RESEND_API_KEY=

# `From:` address shown to recipients. Must be a verified domain on the
# Resend account (default below uses the thalosplatform.xyz domain).
EMAIL_FROM=Thalos <notifications@thalosplatform.xyz>

# `Reply-To:` shown when the recipient hits "Reply" in their client.
# RFC 8058 recommends a clearly non-monitored alias so it never silently
# routes customer replies into an inbox.
EMAIL_REPLY_TO=Thalos <no-reply@thalosplatform.xyz>
