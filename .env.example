# Supabase (service role — solo servidor)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT de la app Thalos (mismo JWT_SECRET que el frontend para login email/OAuth callback)
JWT_SECRET=

# Trustless Work (nunca NEXT_PUBLIC)
TRUSTLESSWORK_API_URL=https://dev.api.trustlesswork.com
TRUSTLESSWORK_API_KEY=

# Secreto compartido Next.js → Nest (proxy Trustless desde /api/trustless)
THALOS_INTERNAL_SECRET=

# CORS (origen del front en dev/prod)
THALOS_CORS_ORIGIN=http://localhost:3000

# URL pública del front (links de invitación en contactos)
THALOS_APP_PUBLIC_URL=http://localhost:3000

# Puerto Nest
PORT=3001
